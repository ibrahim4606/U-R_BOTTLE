<div class="col">
    <div class="gemini-api">
        <h1> Generate AI slogans For Your Brand</h1>
        <form class="needs-validation" action="/design-studio/ai-generate" method="POST" novalidate>
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input name="design[title]" placeholder="Enter Brand Name" type="text" class="form-control border-2"
                    required>
                <div class="valid-feedback">
                    Looks good!
                </div>
                <div class="invalid-feedback">
                    Please Enter Brand Name!
                </div>
            </div>
            <div class="mb-3">
                <label for="BrandType" class="form-label">Brand Type</label>
                <input name="design[BrandType]" placeholder="Brand Type(Hotel,Cafe,etc..)" type="text"
                    class="form-control border-2" required>
                <div class="valid-feedback">
                    Looks good!
                </div>
                <div class="invalid-feedback">
                    Please Enter Type Of Buisness!
                </div>
            </div>
            <div class="mb-3">
                <label for="colors" class="form-label">Theme Colors</label>
                <input name="design[colorTheme]" placeholder="Colors you want to add" type="text"
                    class="form-control border-2" required>
                <div class="valid-feedback">
                    Looks good!
                </div>
                <div class="invalid-feedback">
                    Please Enter Color of Theme!
                </div>
            </div>
            <div class="mb-3">
                <label for="prompt" class="form-label">Description</label>
                <textarea name="design[description]" class="form-control border-2 prompt" type="text" rows="5"
                    placeholder="Description about your logo in summary" maxlength="200" required></textarea>
                <div class="valid-feedback">
                    Looks good!
                </div>
                <div class="invalid-feedback">
                    Please Enter Some if info about your Buisness!
                </div>
            </div>

            <div class="d-flex justify-content-center"><button class="btn mb-3  px-5 ms-1 fs-5"
                    type="submit">Generate</button></div>
        </form>

    </div>
</div>