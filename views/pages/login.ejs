<% layout("/layouts/boilerplate") -%>
    <div class="login-signup-container py-3 py-sm-5" data-aos="zoom-in" data-aos-duration="500">
        <div class="login-signup my-0 my-sm-3" data-aos="fade-up">
            <div class="container">
                <form action="/login" method="POST" class="needs-validation" novalidate>
                    <div class="d-flex align-items-center flex-column border-bottom mb-2 border-secondary-subtle">
                        <h3 style="color: #1394b4;">Welcome Back!</h3>
                        <p class="form-text">Login to your account</p>
                    </div>
                    <div class="mb-3">
                        <label for="exampleInputEmail1" class="form-label">Email address</label>
                        <input type="email" class="form-control border-2" id="exampleInputEmail1"
                            aria-describedby="emailHelp" name="email" required>
                        <div id="emailHelp" class="form-text">We'll never share your email with anyone else.</div>
                    </div>
                    <div class="mb-3">
                        <label for="inputPassword5" class="form-label">Password</label>
                        <input type="password" id="inputPassword5" class="form-control border-2"
                            aria-describedby="passwordHelpBlock" name="password" required>
                        <div id="passwordHelpBlock" class="form-text">
                            Your password must be 8-20 characters long, contain letters and numbers, and must not
                            contain
                            spaces,
                            special characters.
                        </div>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input border-2" id="exampleCheck1" required>
                        <label class="form-check-label ms-1" for="exampleCheck1">Accept Terms and Condition</label>
                    </div>

                    <div class="d-flex justify-content-center"><button class="btn mb-3  px-5 ms-1 fs-5"
                            type="submit">Login</button></div>


                    <div class="d-flex justify-content-center flex-nowrap text-nowrap">
                        <p class="form-text">If you don't have a account ?
                            <a class="icon-link icon-link-hover" href="/signup">
                                Sign-Up
                                <svg xmlns="http://www.w3.org/2000/svg" class="bi" viewBox="0 0 16 16"
                                    aria-hidden="true">
                                    <path
                                        d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z" />
                                </svg>
                            </a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>