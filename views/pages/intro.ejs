<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>U'R Bottle - Photorealistic Cinematic Reveal</title>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            background-color: #020202;
            font-family: sans-serif;
        }

        canvas {
            display: block;
            width: 100vw;
            height: 100vh;
        }

        #loading {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            font-size: 1.2rem;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        #ui-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, transparent 40%, rgba(0, 0, 0, 0.8) 100%);
            color: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            opacity: 0;
            pointer-events: none;
            z-index: 10;
        }

        h1 {
            font-size: 5rem;
            margin: 0;
            font-weight: 300;
            letter-spacing: -2px;
        }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
</head>

<body>

    <div id="loading">Loading High-Fidelity Assets...</div>
    <div id="canvas-container"></div>
    <div id="ui-layer">
        <h1>U'R Bottle</h1>
    </div>

    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.158.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.158.0/examples/jsm/"
            }
        }
    </script>

    <script type="module">
        import * as THREE from 'three';
        import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
        import { RGBELoader } from 'three/addons/loaders/RGBELoader.js';
        import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
        import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
        import { BokehPass } from 'three/addons/postprocessing/BokehPass.js';

        // ==========================================
        // 1. CINEMATIC SCENE & RENDERER SETUP
        // ==========================================
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 100);
        camera.position.set(0, 1.5, 6);

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true, powerPreference: "high-performance" });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2)); // Optimize for high-DPI

        // Photorealistic Color Grading & Shadows
        renderer.toneMapping = THREE.ACESFilmicToneMapping;
        renderer.toneMappingExposure = 1.2;
        renderer.shadowMap.enabled = true;
        renderer.shadowMap.type = THREE.PCFSoftShadowMap;
        document.getElementById('canvas-container').appendChild(renderer.domElement);

        // ==========================================
        // 2. POST-PROCESSING (Depth of Field)
        // ==========================================
        const composer = new EffectComposer(renderer);
        const renderPass = new RenderPass(scene, camera);
        composer.addPass(renderPass);

        // Cinematic Lens Blur
        const bokehPass = new BokehPass(scene, camera, {
            focus: 6.0,       // Distance to the bottle
            aperture: 0.005,  // How wide the lens is open (more blur)
            maxblur: 0.01     // Maximum blur strength
        });
        composer.addPass(bokehPass);

        // ==========================================
        // 3. HDRI ENVIRONMENT & LIGHTING
        // ==========================================
        // We use an HDRI to give the glass real-world reflections
        new RGBELoader().load('path/to/your/studio_lighting.hdr', function (texture) {
            texture.mapping = THREE.EquirectangularReflectionMapping;
            scene.environment = texture; // Applies reflections to materials
            // scene.background = texture; // Optional: show studio in background
        });

        // Add a rim light to separate the bottle from the dark background
        const rimLight = new THREE.SpotLight(0xadd8e6, 50); // Soft icy blue
        rimLight.position.set(-3, 5, -5);
        rimLight.lookAt(0, 1.5, 0);
        scene.add(rimLight);

        const topLight = new THREE.SpotLight(0xffffff, 0); // Cap highlight (off initially)
        topLight.position.set(0, 5, 0);
        scene.add(topLight);

        // ==========================================
        // 4. LOAD THE REAL 3D MODEL (.GLB)
        // ==========================================
        const masterGroup = new THREE.Group();
        masterGroup.position.set(-8, 0, 0); // Start off-screen
        scene.add(masterGroup);

        const pivotGroup = new THREE.Group();
        pivotGroup.rotation.z = -Math.PI / 2; // Laying flat
        masterGroup.add(pivotGroup);

        // Placeholder variables for animated parts
        let bottleMesh, liquidMesh, labelMesh, capMesh;

        const textureLoader = new THREE.TextureLoader();
        const labelTexture = textureLoader.load('path/to/your/label_texture.png');
        labelTexture.flipY = false; // GLTF standard

        const gltfLoader = new GLTFLoader();

        // --- REPLACE 'bottle_model.glb' WITH YOUR FILE PATH ---
        gltfLoader.load('bottle_model.glb', (gltf) => {
            const model = gltf.scene;
            pivotGroup.add(model);

            // Traverse the model and apply hyper-realistic materials
            model.traverse((child) => {
                if (child.isMesh) {
                    child.castShadow = true;
                    child.receiveShadow = true;

                    // A. THE REAL GLASS / PREMIUM PLASTIC
                    if (child.name === 'Bottle') {
                        bottleMesh = child;
                        child.material = new THREE.MeshPhysicalMaterial({
                            color: 0xffffff,
                            metalness: 0.1,
                            roughness: 0.05,
                            transmission: 1.0, // Glass transparency
                            ior: 1.5,          // Index of Refraction for Glass
                            thickness: 0.2,    // Physical thickness for refraction
                            clearcoat: 1.0,    // Extra glossy reflection layer
                            clearcoatRoughness: 0.1
                        });
                    }

                    // B. THE REAL WATER
                    if (child.name === 'Liquid') {
                        liquidMesh = child;
                        liquidMesh.scale.y = 0.01; // Start empty
                        child.material = new THREE.MeshPhysicalMaterial({
                            color: 0xcceeff,     // Slight blue tint
                            transmission: 0.95,
                            ior: 1.33,           // Index of Refraction for Water
                            roughness: 0.1,
                            thickness: 0.5
                        });
                    }

                    // C. THE REAL BRANDED LABEL
                    if (child.name === 'Label') {
                        labelMesh = child;
                        labelMesh.material.transparent = true;
                        labelMesh.material.opacity = 0; // Hidden initially
                        child.material = new THREE.MeshStandardMaterial({
                            map: labelTexture,
                            roughness: 0.6, // Matte paper/plastic finish
                            metalness: 0.1,
                            transparent: true,
                            opacity: 0
                        });
                    }

                    // D. THE PREMIUM CAP
                    if (child.name === 'Cap') {
                        capMesh = child;
                        capMesh.position.y += 2; // Hover above initially
                        child.material = new THREE.MeshStandardMaterial({
                            color: 0x111111,
                            roughness: 0.3,
                            metalness: 0.8 // Metallic finish
                        });
                    }
                }
            });

            // Hide loading text and start animation
            document.getElementById('loading').style.display = 'none';
            playCinematicChoreography();
        });

        // ==========================================
        // 5. CINEMATIC GSAP TIMELINE
        // ==========================================
        const cameraTarget = new THREE.Vector3(0, 1.5, 0);

        function playCinematicChoreography() {
            const tl = gsap.timeline({ defaults: { ease: "power2.inOut" } });

            // 1. Roll into center
            tl.to(masterGroup.position, { x: 0, duration: 2, ease: "power3.out" }, 0);
            tl.to(pivotGroup.children[0].rotation, { z: Math.PI * -4, duration: 2, ease: "power3.out" }, 0); // Roll the bottle model

            // 2. Stand upright
            tl.to(pivotGroup.rotation, { z: 0, duration: 1.5 }, 1.2);

            // 3. Water fill & Label wrap
            if (liquidMesh) tl.to(liquidMesh.scale, { y: 1, duration: 1.5, ease: "power1.inOut" }, 2.5);
            if (labelMesh) tl.to(labelMesh.material, { opacity: 1, duration: 1 }, 2.5);

            // 4. Cap twists down
            if (capMesh) {
                tl.to(capMesh.position, { y: "-=2", duration: 1, ease: "power2.in" }, 3.5);
                tl.to(capMesh.rotation, { y: Math.PI * 2, duration: 1, ease: "power2.out" }, 3.5);
            }

            // 5. Camera swoop to top-down
            tl.to(camera.position, { x: 0, y: 5.5, z: 0, duration: 2.5, ease: "power3.inOut" }, 4.5);
            tl.to(cameraTarget, { x: 0, y: 3.5, z: 0, duration: 2.5, ease: "power3.inOut" }, 4.5);

            // Adjust Depth of Field focus as camera moves
            tl.to(bokehPass.uniforms.focus, { value: 2.0, duration: 2.5 }, 4.5);

            // 6. Lighting shift for logo reveal
            tl.to(scene.environment, { intensity: 0.2, duration: 1.5 }, 5.0); // Dim HDR reflections
            tl.to(topLight, { intensity: 100, duration: 1.5 }, 5.0); // Spotlight on the cap logo

            // 7. UI Fade in
            tl.to(document.getElementById('ui-layer'), { opacity: 1, duration: 1, pointerEvents: 'auto' }, 6.5);
        }

        // ==========================================
        // 6. RENDER LOOP (Using Composer for DOF)
        // ==========================================
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
            composer.setSize(window.innerWidth, window.innerHeight);
        });

        function animate() {
            requestAnimationFrame(animate);
            camera.lookAt(cameraTarget);

            // Render through the composer to get the Depth of Field effect
            composer.render();
        }
        animate();
    </script>
</body>

</html>