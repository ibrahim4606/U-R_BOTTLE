<% layout("/layouts/boilerplate") -%>
    <section class="container py-5">

        <div class="text-center mb-5" data-aos="fade-down">
            <h2 class="fw-bold">How It Works</h2>
            <p class="text-muted">Follow these simple steps to design and order your custom branded bottle.</p>
        </div>

        <div class="row g-4">

            <!-- Step 1 -->
            <div class="col-md-6 col-lg-4" data-aos="flip-right">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body">
                        <div class="fs-1 text-primary mb-3">
                            <i class="fa-solid fa-user-plus"></i>
                        </div>
                        <h6 class="fw-bold">Step 1</h6>
                        <h5>Create Account</h5>
                        <p class="text-muted small">
                            Register on the platform to access all customization tools and manage your orders easily.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="col-md-6 col-lg-4" data-aos="flip-right">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body">
                        <div class="fs-1 text-primary mb-3">
                            <i class="fa-solid fa-wand-magic-sparkles"></i>
                        </div>
                        <h6 class="fw-bold">Step 2</h6>
                        <h5>Generate AI Design</h5>
                        <p class="text-muted small">
                            Use our AI generator to create unique bottle branding ideas based on your brand concept.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="col-md-6 col-lg-4" data-aos="flip-right">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body">
                        <div class="fs-1 text-primary mb-3">
                            <i class="fa-solid fa-palette"></i>
                        </div>
                        <h6 class="fw-bold">Step 3</h6>
                        <h5>Customize Bottle</h5>
                        <p class="text-muted small">
                            Select bottle size, colors, logo, slogan, and design elements to match your branding.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Step 4 -->
            <div class="col-md-6 col-lg-4" data-aos="flip-right">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body">
                        <div class="fs-1 text-primary mb-3">
                            <i class="fa-solid fa-cart-shopping"></i>
                        </div>
                        <h6 class="fw-bold">Step 4</h6>
                        <h5>Add To Cart</h5>
                        <p class="text-muted small">
                            Once your design is ready, add the customized bottle to your cart for ordering.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Step 5 -->
            <div class="col-md-6 col-lg-4" data-aos="flip-right">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body">
                        <div class="fs-1 text-primary mb-3">
                            <i class="fa-solid fa-credit-card"></i>
                        </div>
                        <h6 class="fw-bold">Step 5</h6>
                        <h5>Place Order</h5>
                        <p class="text-muted small">
                            Enter delivery details and confirm your order to start the bottle production process.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Step 6 -->
            <div class="col-md-6 col-lg-4" data-aos="flip-right">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body">
                        <div class="fs-1 text-primary mb-3">
                            <i class="fa-solid fa-truck-fast"></i>
                        </div>
                        <h6 class="fw-bold">Step 6</h6>
                        <h5>Track Delivery</h5>
                        <p class="text-muted small">
                            Track your order status and receive your custom branded bottles at your doorstep.
                        </p>
                    </div>
                </div>
            </div>
            <hr>
            <div class="d-flex justify-content-center mt-3">
                <a href="/design-studio" class="btn edit-btn ms-2 mt-1 btn-lg" data-aos="zoom-out">Start Your
                    Designing</a>
            </div>

        </div>

    </section>