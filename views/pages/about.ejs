<% layout("/layouts/boilerplate") -%>





    <!-- ABOUT CONTENT -->

    <div class="container py-5">
        <!-- HERO SECTION -->

        <section class="about-hero" data-aos="fade-right">
            <div data-aos="fade-right">
                <h1>About Our Company</h1>
                <p class="lead">Delivering high quality customized water bottles</p>
            </div>
        </section>
        <br>
        <div class="row align-items-center">

            <div class="col-md-6">

                <h2 data-aos="fade-right">Who We Are</h2>

                <p class="text-muted" data-aos="fade-right">
                    We are a modern packaging company focused on providing customized
                    water bottle solutions for events, businesses, and branding needs.
                    Our goal is to deliver high quality bottles with unique label
                    designs that make your brand stand out.
                </p>

                <p class="text-muted" data-aos="fade-right">
                    Using advanced printing technology and creative designs,
                    we help businesses create personalized water bottles
                    for weddings, corporate events, hotels, and promotions.
                </p>

            </div>

            <div class="col-md-6">

                <img src="/images/about-us-img.png" style="max-height:300px; min-width: 540px;"
                    class="img-fluid object-fit-cover border border-2 rounded-3 shadow ms-3" data-aos="fade-left">

            </div>

        </div>

    </div>


    <!-- FEATURES -->
    <div class="container py-5">

        <hr class="mb-5 border border-black">
        <div class="about-text text-center mb-5">
            <h2 data-aos="fade-down">Why Choose Us</h2>
            <p class="text-muted" data-aos="fade-down">Our services are designed for quality and reliability</p>
        </div>

        <div class="row g-4">

            <div class="col-md-4" data-aos="flip-right">
                <div class="card about-card p-4 text-center shadow">
                    <div class="feature-icon mb-3">
                        <i class="fa-solid fa-bottle-water"></i>
                    </div>
                    <h5>Premium Quality</h5>
                    <p class="text-muted">
                        We use high quality bottles and labels for durable packaging.
                    </p>
                </div>
            </div>

            <div class="col-md-4" data-aos="flip-right">
                <div class="card about-card p-4 text-center shadow">
                    <div class="feature-icon mb-3">
                        <i class="fa-solid fa-palette"></i>
                    </div>
                    <h5>Custom Design</h5>
                    <p class="text-muted">
                        Upload your logo or generate AI designs for unique branding.
                    </p>
                </div>
            </div>

            <div class="col-md-4" data-aos="flip-right">
                <div class="card about-card p-4 text-center shadow">
                    <div class="feature-icon mb-3">
                        <i class="fa-solid fa-truck-fast"></i>
                    </div>
                    <h5>Fast Delivery</h5>
                    <p class="text-muted">
                        We ensure quick processing and reliable and fast delivery.
                    </p>
                </div>
            </div>

        </div>

    </div>


    <!-- TEAM -->

    <div class="container py-5">

        <div class="text-center mb-5">
            <h2 data-aos="fade-down" data-aos="fade-down">Our Mission</h2>
        </div>

        <div class="row justify-content-center">

            <div class="col-md-8 text-center">

                <p class="lead text-muted" data-aos="fade-down">
                    Our mission is to make personalized packaging simple and affordable
                    for everyone. From small events to large businesses,
                    we help bring branding ideas to life through customized water bottles.
                </p>

            </div>

        </div>
        <hr>
        <div class="d-flex justify-content-center mt-5">
            <a href="/design-studio" class="btn edit-btn ms-2 mt-1 btn-lg" data-aos="zoom-out">Start Your
                Designing</a>
        </div>

    </div>