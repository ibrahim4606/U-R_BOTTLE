<% layout("/layouts/boilerplate") -%>

    <div class="container mt-5">

        <!-- Heading -->
        <div class="text-center mb-5">
            <h2 class="fw-bold text-dark" data-aos="fade-down">
                <i class="fa-solid fa-cart-shopping me-2"></i> Your Cart
            </h2>
            <p class="text-muted" data-aos="fade-down">
                Review your selected items and proceed to checkout.
            </p>
        </div>


        <% if(cart.length===0){ %>

            <div class="alert alert-info" data-aos="zoom-in">
                Your cart is empty.
            </div>

            <% } %>


                <div class="row row-cols-lg-2 row-cols-md-1">

                    <% cart.forEach(c=> { %>
                        <% c.items.forEach(item=> { %>

                            <div class="col">

                                <div class="card mb-5 shadow-sm position-relative" style="max-width:720px;"
                                    data-aos="fade-down">

                                    <!-- DELETE ICON -->
                                    <form action="/cart/<%= c._id %>?_method=DELETE" method="POST"
                                        style="position:absolute; right:15px; top:10px;">
                                        <button class="btn btn-sm text-danger border-0 text-white">
                                            <i class="fa-solid fa-trash fs-5"></i>
                                        </button>
                                    </form>

                                    <div class="row">

                                        <!-- Bottle Image -->
                                        <div class="col d-flex align-items-center justify-content-center p-3"
                                            data-aos="flip-right">

                                            <img src="<%= item.logo %>" class="img-fluid rounded"
                                                style="max-height:200px;">
                                        </div>


                                        <!-- Details -->
                                        <div class="col" data-aos="fade-right">

                                            <div class="card-body">

                                                <h5 class="card-title fw-bold text-danger">
                                                    <%= item.title %>
                                                </h5>

                                                <p class="card-text mb-1">
                                                    <strong>Brand Type:</strong>
                                                    <%= item.BrandType %>
                                                </p>

                                                <p class="card-text mb-1">
                                                    <strong>Volume:</strong>
                                                    <%= item.bottleVolume %> ML
                                                </p>

                                                <p class="card-text mb-1">
                                                    <strong>Units:</strong>
                                                    <%= item.units %>
                                                </p>

                                                <p class="card-text mb-1">
                                                    <strong>Price / Unit:</strong>
                                                    ₹ <%= item.perUnitPrice %>
                                                </p>

                                                <p class="card-text fw-bold text-success">
                                                    Total Price: ₹ <%= item.TotalPrice %>
                                                </p>

                                                <p class="card-text">
                                                    <small class="text-body-secondary">
                                                        Added <%= new Date(c.createdAt).toLocaleString() %>
                                                    </small>
                                                </p>

                                                <!-- PLACE ORDER BUTTON -->
                                                <a href="/checkout" class="btn btn-primary mt-2 px-5">
                                                    Place Order
                                                </a>

                                            </div>

                                        </div>

                                    </div>

                                </div>

                            </div>

                            <% }) %>
                                <% }) %>

                </div>
                <hr class="mt-3 border border-black">
                <div class="d-flex justify-content-center my-5">
                    <a href="/design-studio" class="btn edit-btn ms-2 mt-1 btn-lg" data-aos="zoom-out">Start Your
                        Designing</a>
                </div>
    </div>