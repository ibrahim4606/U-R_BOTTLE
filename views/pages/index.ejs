<% layout("/layouts/boilerplate") -%>

    <div>
        <div class="hero-section" data-aos="fade-down">
            <picture>
                <source media="(max-width: 768px)" srcset="/images/banner1.png">
                <img src="/images/banner.png" class="object-fit-cover" style="width:100%; height:100vh;" alt="banner">
            </picture>
            <div class="hero-content" data-aos="fade-right">
                <h1 style="font-size: 3.2rem;">Design Your Own <br> Water Bottle In Minutes</h1>
                <p class=" fs-5 text-body-secondary">Create your personalized water bottle with unique
                    designs quickly
                    and easily.</p>
                <a href="/design-studio" class="btn edit-btn ms-2 px-3 mt-1 btn-lg"> Start Designing
                </a>
            </div>
        </div>

        <div class="container my-5">
            <h2 data-aos="fade-down">Why Choose Us?</h2>
            <div class="row m-2 g-3">

                <div class="col-12 col-sm-5 p-5" data-aos="fade-down">
                    <div class="d-flex align-items-center mb-3" data-aos="fade-up">
                        <i class="fa-solid fa-medal fs-3 icon rounded-3 me-3"></i>
                        <div>
                            <h5 class="fw-medium">Premium Quality</h5>
                            <p class="text-body-secondary">We Provide Good Quality of drinking Water</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center mb-3" data-aos="fade-up">
                        <i class="fa-solid fa-sliders fs-3 icon rounded-3 me-3"></i>
                        <div>
                            <h5 class="fw-medium">Custom Label Designing</h5>
                            <p class="text-body-secondary">You can customize your Branding Label's</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center mb-3" data-aos="fade-up">
                        <i class="fa-solid fa-recycle fs-3 icon rounded-3 me-3"></i>
                        <div>
                            <h5 class="fw-medium">Eco - Friendly</h5>
                            <p class="text-body-secondary">Bottel's are fully Recycle</p>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-7" data-aos="zoom-in-up">
                    <img src="/images/chooseus-img.png" class="rounded-3 shadow object-fit-cover"
                        style="width:100%; height:100%;" alt="image">
                </div>
            </div>

            <hr class="mt-5 border border-black">


            <div class="row align-items-start">


                <div class="col-12 col-sm-4 p-3 choose-border mb-4 mb-sm-0">



                    <h4 data-aos="fade-right">Add Your Review</h4>

                    <form action="/home/reviews" method="POST" class="needs-validation" data-aos="fade-right"
                        novalidate>

                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input type="text" name="review[name]" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Rating</label>
                            <select name="review[rating]" class="form-control">

                                <option value="5">5 ⭐</option>
                                <option value="4">4 ⭐</option>
                                <option value="3">3 ⭐</option>
                                <option value="2">2 ⭐</option>
                                <option value="1">1 ⭐</option>

                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Comment</label>
                            <textarea name="review[comment]" class="form-control" required></textarea>
                        </div>

                        <button class="btn ">Submit Review</button>

                    </form>
                </div>

                <div class="col-12 col-sm-8 p-3">
                    <h2 class="mb-4" data-aos="fade-up">Customer Reviews</h2>

                    <div class="reviews-container row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

                        <% reviews.forEach(r=> { %>
                            <div class="col-12 col-md-6 col-lg-4 d-flex">
                                <div class="card review-card shadow-sm w-100">

                                    <h6>
                                        <%= r.name %>
                                    </h6>

                                    <p class="text-warning mb-2">
                                        <% for(let i=0;i<r.rating;i++){ %> ★ <% } %>
                                    </p>

                                    <p class="review-text">
                                        <%= r.comment %>
                                    </p>

                                </div>
                            </div>

                            <% }) %>

                    </div>
                </div>

            </div>

            <hr class="mt-3 border border-black">
            <div class="d-flex justify-content-center mt-5">
                <a href="/design-studio" class="btn edit-btn ms-2 mt-1 btn-lg" data-aos="zoom-out">Start
                    Your
                    Designing</a>
            </div>
        </div>
    </div>