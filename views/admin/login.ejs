<% layout("/admin/admin-boilerplate") -%>
    <div class="container vh-100 d-flex justify-content-center align-items-center">
        <div class="d-flex justify-content-center">
            <div class="position-absolute z-3 mt-3 rounded-3">
            </div>
        </div>

        <div class="card shadow p-5 justify-content-center align-items-center" style="width:500px; height: 350px;">

            <h4 class="text-center mb-3">
                <i class="fa-solid fa-user-shield"></i> Admin Login
            </h4>

            <form action="/admin/login" method="POST" class="needs-validation" novalidate>

                <div class="mb-3">

                    <label class="form-label">Enter Admin Password</label>

                    <input type="password" class="form-control" name="password" required>

                </div>

                <button class="btn btn-dark w-100">
                    Access Dashboard
                </button>

            </form>

        </div>

    </div>