<div class="container mt-5">

    <h4 class="mb-4" data-aos="fade-down">
        <i class="fa-solid fa-box"></i> Orders
    </h4>

    <div class="row">

        <% orders.forEach((order,index)=>{ %>

            <div class="col-lg-6">

                <div class="card shadow mb-4 border-0" data-aos="fade-up">

                    <div class="card-body">

                        <!-- CARD HEADER -->

                        <div class="d-flex justify-content-between align-items-center mb-2">

                            <h6 class="fw-bold mb-0 ">
                                Order No. <%= orders.length - index %>
                            </h6>

                            <span class="badge <% if(order.shippingDetails.orderStatus===" Delivered"){ %>
                                bg-success
                                <% } else if(order.shippingDetails.orderStatus==="In Progress" ){ %>
                                    bg-warning
                                    <% } else if(order.shippingDetails.orderStatus==="Rejected" ){ %>
                                        bg-danger
                                        <% } else { %>
                                            bg-secondary
                                            <% } %>

                                                ">

                                                <%= order.shippingDetails.orderStatus %>

                            </span>

                        </div>

                        <hr>

                        <div class="d-flex justify-content-between align-items-center mb-2 px-3 cursor-pointer"
                            data-bs-toggle="collapse" data-bs-target="#collapse<%=order._id%>" aria-expanded="false"
                            aria-controls="collapse<%=order._id%>">

                            <span class="fw-semibold">
                                View Details
                            </span>

                            <i class="fa-solid fa-angle-down rotate-icon"></i>

                        </div>

                        <div class="collapse" id="collapse<%=order._id%>">

                            <!-- ORDER INFO -->

                            <p class="mb-1">
                                <b>Order ID:</b>
                                <%= order.orderNumber %>
                            </p>

                            <p class="mb-1">
                                <b>Date:</b>
                                <%= new Date(order.createdAt).toDateString() %>
                            </p>

                            <p class="mb-1">
                                <b>Total:</b> ₹ <%= order.totalAmount %>
                            </p>

                            <hr>

                            <!-- CUSTOMER DETAILS -->

                            <h6 class="fw-bold">Customer</h6>

                            <p class="mb-1">
                                <b>Name:</b>
                                <%= order.shippingDetails.fullName %>
                            </p>

                            <p class="mb-1">
                                <b>Phone:</b>
                                <%= order.shippingDetails.phone %>
                            </p>

                            <p class="mb-1">
                                <b>City:</b>
                                <%= order.shippingDetails.city %>
                            </p>

                            <p class="mb-2">
                                <b>Address:</b>
                                <%= order.shippingDetails.address %>
                            </p>

                        </div>
                        <hr>

                        <!-- ITEMS -->

                        <h6 class="fw-bold">Items</h6>

                        <% order.items.forEach(item=>{ %>

                            <div class="border rounded p-2 mb-2">

                                <div class="d-flex align-items-center">

                                    <img src="<%= item.logo %>" width="60" class="me-2">

                                    <div>

                                        <p class="mb-0 fw-bold">
                                            <%= item.title %>
                                        </p>

                                        <small>
                                            Units: <%= item.units %> |
                                                Price: ₹ <%= item.perUnitPrice %>
                                        </small>

                                    </div>

                                </div>

                            </div>

                            <% }) %>

                                <!-- REJECT REASON -->

                                <% if(order.shippingDetails.orderStatus==="Rejected" ){ %>

                                    <div class="alert alert-danger mt-3">

                                        <b>Rejected Reason:</b>

                                        <p class="mb-0">
                                            <%= order.shippingDetails.rejectReason %>
                                        </p>

                                    </div>

                                    <% } %>

                                        <!-- UPDATE BUTTONS -->

                                        <% if(order.shippingDetails.orderStatus !=="Delivered" &&
                                            order.shippingDetails.orderStatus !=="Rejected" ){ %>
                                            <div class="mt-3 d-flex justify-content-end gap-2 flex-wrap">

                                                <button class="btn me-3"
                                                    onclick="openConfirmModal('<%=order._id%>','In Progress')">

                                                    In Progress

                                                </button>

                                                <button class="btn me-3"
                                                    onclick="openConfirmModal('<%=order._id%>','Delivered')">

                                                    Delivered

                                                </button>

                                                <button class="btn me-3" data-bs-toggle="modal"
                                                    data-bs-target="#rejectModal<%=order._id%>">

                                                    Reject

                                                </button>

                                            </div>

                                            <% } %>

                    </div>

                </div>

            </div>
            <%- include("order-status-confirm") %>
                <%- include("reject-reason", { order: order }) %>

                    <% }) %>

    </div>

</div>